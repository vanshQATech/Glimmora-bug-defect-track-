{
  "name": "bug-tracking-platform",
  "version": "1.0.0",
  "description": "Custom Bug Tracking and Team Work Management Platform",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.1",
    "sql.js": "^1.11.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  }
}
